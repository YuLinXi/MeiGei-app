# 生产机密模板。复制为 .env.prod 并填真实值（.env.prod 已被 .gitignore 忽略，勿提交）。
#   cp .env.prod.example .env.prod
# 随机密钥生成：openssl rand -base64 48

# ── 数据库 ──────────────────────────────────────────────
# 共享 PG 实例里 dontlift 角色的密码；必须与 deploy/shared-infra/db/.env 的 DONTLIFT_DB_PASSWORD 完全一致
# （连接地址在 docker-compose.prod.yml 里硬编码为 shared-postgres:5432/dontlift，无需在此配）
DB_PASSWORD=

# ── 安全 ────────────────────────────────────────────────
# JWT 签名密钥，HS256 要求 >= 32 字节；务必随机，泄露=可伪造任意登录态
JWT_SECRET=
# 免 Apple 造 token 的开发端点，生产必须保持 false
APP_DEV_TOKEN=false

# ── Sign in with Apple ─────────────────────────────────
# 你真实的 App Bundle ID（aud 校验，必须与客户端一致）
APPLE_AUDIENCES=com.yulinxi.app.DontLift

# ── 错误上报（可选）────────────────────────────────────
SENTRY_DSN=
SENTRY_ENV=production

# ── APNs 推送（有凭据后再填；留空则推送静默 no-op）──────
# .p8 私钥请放到 backend/secrets/apns.p8，并在 compose 取消 volumes 挂载注释
APNS_KEY_PATH=/secrets/apns.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_TOPIC=com.yulinxi.app.DontLift
APNS_PRODUCTION=true
