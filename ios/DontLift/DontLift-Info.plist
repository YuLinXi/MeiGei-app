<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  主 App 的 Info.plist 基底文件（仅放无法用 INFOPLIST_KEY_* 注入的嵌套字典）。
	  GENERATE_INFOPLIST_FILE=YES 仍会把 HealthKit 用途串 / NSSupportsLiveActivities /
	  字体 / 场景清单等 INFOPLIST_KEY_* 在构建时 merge 进来，故此处不必重复声明。

	  ATS：公网一律强制 HTTPS；仅留 NSAllowsLocalNetworking 放行本地明文
	  （模拟器 Debug 联调 localhost:8001 用，随包发布无害、不影响过审）。
	  勿再加回 NSAllowsArbitraryLoads——公网明文口子已随 HTTPS 上线删除（2026-06-11）。
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.yulinxi.app.DontLift</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>dontlift</string>
			</array>
		</dict>
	</array>
	<!-- 仅用系统标准加密（HTTPS/Keychain），属豁免范围；声明后每次上传 TestFlight 免答出口合规问卷。 -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
